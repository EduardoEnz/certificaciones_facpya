<section class="py-5 bg-light">
  <div class="container py-4">
    <div class="text-center mb-5">
      <h2 class="section-title">Próximos Eventos y Conferencias</h2>
      <p class="text-secondary">Regístrate para asegurar tu lugar.</p>
    </div>

    <div class="row g-4">
      <% @events.each do |event| %>
        <div class="col-md-6">
          <div class="card p-4 shadow-sm border-0 h-100">
            <h4 class="fw-bold text-navy"><%= event.title %></h4>
            <p class="text-secondary mb-3">
              <i class="bi bi-calendar-event me-2"></i> 
              Registro: <%= event.start_date.strftime("%d/%m/%Y") %> al <%= event.end_date.strftime("%d/%m/%Y") %>
            </p>
            <p class="text-secondary mb-4">
              <i class="bi bi-people me-2"></i> Cupo máximo: <%= event.capacity %> personas
            </p>

            <div class="mt-auto">
              <button class="btn btn-outline-secondary w-100 fw-bold mb-2" data-bs-toggle="modal" data-bs-target="#detallesModal<%= event.id %>">
                Ver Detalles de la Conferencia
              </button>

              <% if event.registration_open? %>
                <% if event.full? %>
                  <div class="alert alert-danger mb-0 text-center">Cupo Lleno</div>
                <% else %>
                  <button class="btn btn-gold w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#registroModal<%= event.id %>">
                    Registrarse
                  </button>
                <% end %>
              <% else %>
                <div class="alert alert-warning mb-0 text-center">Registro no disponible por el momento</div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Modal de Detalles -->
        <div class="modal fade" id="detallesModal<%= event.id %>" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-navy"><%= event.title %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%= simple_format(event.description) %> 
              </div>
            </div>
          </div>
        </div>

        <!-- Modal de Registro -->
        <div class="modal fade" id="registroModal<%= event.id %>" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header bg-navy text-white">
                <h5 class="modal-title">Registro: <%= event.title %></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <%= form_with(url: registrations_path, method: :post, local: true) do |f| %>
                  <%= f.hidden_field :event_id, value: event.id %>

                  <div class="mb-3">
                    <%= f.label :role, "¿Eres Alumno o Maestro?", class: "form-label fw-bold" %>
                    <%= f.select :role, ["Alumno", "Maestro"], { prompt: "Selecciona tu rol" }, { class: "form-select role-selector", required: true } %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :is_uanl, "¿Eres de la UANL?", class: "form-label fw-bold" %>
                    <%= f.select :is_uanl, ["Si", "No"], { prompt: "Selecciona una opción" }, { class: "form-select", required: true } %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :faculty, "Facultad a la que perteneces", class: "form-label" %>
                    <%= f.text_field :faculty, class: "form-control", required: true %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :name, "Nombre Completo", class: "form-label" %>
                    <%= f.text_field :name, class: "form-control", required: true %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :email, "Correo Electrónico", class: "form-label" %>
                    <%= f.email_field :email, class: "form-control", required: true %>
                  </div>

                  <div class="mb-3">
                    <%= f.label :phone, "Celular", class: "form-label" %>
                    <%= f.telephone_field :phone, class: "form-control", required: true %>
                  </div>

                  <div id="student-fields-<%= event.id %>">
                    <div class="mb-3">
                      <%= f.label :matricula, "Matrícula", class: "form-label" %>
                      <%= f.text_field :matricula, class: "form-control" %>
                    </div>
                    <div class="mb-3">
                      <%= f.label :career, "Carrera", class: "form-label" %>
                      <%= f.text_field :career, class: "form-control" %>
                    </div>
                  </div>

                  <%= f.submit "Completar Registro", class: "btn btn-gold w-100 fw-bold mt-3" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.role-selector').forEach(selector => {
      selector.addEventListener('change', function() {
        const eventId = this.form.querySelector('input[name="event_id"]').value;
        const studentFields = document.getElementById('student-fields-' + eventId);
        
        if (this.value === 'Maestro') {
          studentFields.style.display = 'none';
          studentFields.querySelectorAll('input').forEach(i => i.removeAttribute('required'));
        } else {
          studentFields.style.display = 'block';
          studentFields.querySelectorAll('input').forEach(i => i.setAttribute('required', 'true'));
        }
      });
    });
  });
</script>