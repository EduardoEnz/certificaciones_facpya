<%# ===== HERO ===== %>
<section class="hero-section" style="background-image: linear-gradient(rgba(10, 25, 47, 0.85), rgba(10, 25, 47, 0.85)), url('<%= asset_path('fondo-hero.jpg') %>'); background-size: cover; background-position: center; background-repeat: no-repeat;">
  <div class="container py-5 position-relative" style="z-index:1;">
    <div class="hero-badge mb-3">
      <span class="dot"></span>
      <span>UANL · FACPYA · Certificaciones 2025</span>
    </div>
    <h1 class="hero-title mt-3 mb-3">
      Certifica tu talento,<br>
      <span>impulsa tu carrera.</span>
    </h1>
    <p class="hero-subtitle mb-4">
      Programas de certificación respaldados por FACPYA-UANL.
      Desarrolla las competencias que las empresas de Monterrey buscan hoy.
    </p>
    <div class="d-flex gap-3 flex-wrap">
      <%= link_to "Ver Certificaciones", certifications_path, class: "btn btn-gold btn-lg px-4" %>
      <button class="btn btn-outline-light btn-lg px-4"
              data-bs-toggle="modal" data-bs-target="#leadModal">
        Solicitar Información
      </button>
    </div>
  </div>

  <div class="stats-strip mt-auto">
    <div class="container">
      <div class="d-flex flex-wrap justify-content-center">
        <% [["4","Certificaciones"],["500+","Egresados"],["95%","Satisfacción"],["100%","Valor curricular"]].each do |v,l| %>
          <div class="stat-item">
            <div class="stat-value"><%= v %></div>
            <div class="stat-label"><%= l %></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>