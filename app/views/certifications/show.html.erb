<section class="py-5 bg-light">
  <div class="container py-4">
    <div class="mb-4">
      <%= link_to certifications_path, class: "text-decoration-none text-secondary small fw-bold" do %>
        <i class="bi bi-arrow-left me-1"></i> Volver a certificaciones
      <% end %>
    </div>

    <div class="row g-5">
      <div class="col-lg-8">
        <span class="badge bg-primary mb-3 px-3 py-2"><%= @certification.category %></span>
        <h1 class="fw-black text-navy mb-4" style="font-size: 2.5rem;"><%= @certification.title %></h1>
        
        <h4 class="fw-bold text-navy mt-5 mb-3">Descripción del programa</h4>
        <p class="text-secondary lh-lg" style="font-size: 1.1rem;">
          <%= @certification.description %>
        </p>

        <h4 class="fw-bold text-navy mt-5 mb-4">Temario</h4>
        <ul class="list-group list-group-flush border-top">
          <% @certification.syllabus.split("\n").each do |tema| %>
            <li class="list-group-item bg-transparent py-3 px-0 text-secondary">
              <i class="bi bi-check2-circle text-gold me-2"></i> <%= tema %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 100px;">
          <div class="card-body p-4">
            <h3 class="fw-black text-navy mb-4">$<%= number_with_delimiter(@certification.price.to_i) %> <span class="fs-6 text-muted fw-normal">MXN</span></h3>
            
            <ul class="list-unstyled mb-4">
              <li class="mb-3 d-flex align-items-center text-secondary">
                <i class="bi bi-calendar-event fs-5 me-3 text-gold"></i>
                <div>
                  <small class="d-block text-muted" style="font-size: 0.75rem;">INICIO</small>
                  <span class="fw-bold"><%= @certification.start_date&.strftime("%d de %B, %Y") %></span>
                </div>
              </li>
              <li class="mb-3 d-flex align-items-center text-secondary">
                <i class="bi bi-clock fs-5 me-3 text-gold"></i>
                <div>
                  <small class="d-block text-muted" style="font-size: 0.75rem;">DURACIÓN</small>
                  <span class="fw-bold"><%= @certification.duration %></span>
                </div>
              </li>
              <li class="mb-3 d-flex align-items-center text-secondary">
                <i class="bi bi-laptop fs-5 me-3 text-gold"></i>
                <div>
                  <small class="d-block text-muted" style="font-size: 0.75rem;">MODALIDAD</small>
                  <span class="fw-bold"><%= @certification.modality %></span>
                </div>
              </li>
            </ul>

            <button class="btn btn-gold w-100 py-3 fw-bold rounded-3" 
                    data-bs-toggle="modal" 
                    data-bs-target="#leadModal"
                    onclick="document.querySelector('select[name=\'certification_id\']').value = '<%= @certification.id %>'">
              Inscribirme ahora
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>