<%# Hero de la certificación %>
<% 
  gradients = {
    "Tecnología" => "linear-gradient(135deg,#1D4ED8,#3B82F6)",
    "Gestión"    => "linear-gradient(135deg,#6D28D9,#A78BFA)",
    "Marketing"  => "linear-gradient(135deg,#B91C1C,#F87171)"
  }
  gradient = gradients[@certification.category] || "linear-gradient(135deg,#374151,#6B7280)"
%>

<div style="background:<%= gradient %>; padding: 60px 0 40px;">
  <div class="container">
    <a href="<%= certifications_path %>" 
       class="text-white-50 text-decoration-none small mb-3 d-inline-block">
      ← Volver al catálogo
    </a>
    <div class="d-flex align-items-center gap-3 mb-3">
      <span class="badge bg-white fw-bold" 
            style="color:<%= gradients[@certification.category]&.include?('1D4ED8') ? '#1D4ED8' : '#6D28D9' %>">
        <%= @certification.category&.upcase %>
      </span>
      <span class="badge" style="background:rgba(255,255,255,0.2);color:white;">
        <%= @certification.modality %>
      </span>
    </div>
    <h1 class="text-white fw-black mb-2" style="font-size:clamp(32px,5vw,52px);">
      <%= @certification.title %>
    </h1>
    <p class="mb-0" style="color:rgba(255,255,255,0.75);font-size:17px;">
      <%= @certification.description&.split(".")&.first %>.
    </p>
  </div>
</div>

<%# Contenido principal %>
<div class="container py-5">
  <div class="row g-5">

    <%# Columna izquierda %>
    <div class="col-lg-8">

      <%# Descripción completa %>
      <div class="mb-5">
        <h4 class="fw-black text-navy mb-3">
          <i class="bi bi-file-text me-2" style="color:var(--gold);"></i>
          Descripción del programa
        </h4>
        <p class="text-secondary lh-lg" style="font-size:16px;">
          <%= @certification.description %>
        </p>
      </div>

      <%# Temario %>
      <% if @certification.syllabus.present? %>
        <div class="mb-5">
          <h4 class="fw-black text-navy mb-4">
            <i class="bi bi-list-check me-2" style="color:var(--gold);"></i>
            Temario
          </h4>
          <div class="row g-3">
            <% @certification.syllabus_items.each_with_index do |item, i| %>
              <div class="col-md-6">
                <div class="d-flex align-items-start gap-3 p-3 rounded-3 border bg-light">
                  <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 fw-bold"
                       style="width:32px;height:32px;background:var(--navy);color:var(--gold);font-size:13px;">
                    <%= i + 1 %>
                  </div>
                  <span class="text-secondary" style="font-size:14px;line-height:1.5;">
                    <%= item %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Lo que aprenderás %>
      <div class="p-4 rounded-4" style="background:var(--navy);">
        <h5 class="text-white fw-black mb-3">
          ¿Por qué certificarte con FACPYA?
        </h5>
        <div class="row g-3">
          <% [
            ["bi-award",         "Certificado oficial avalado por FACPYA-UANL"],
            ["bi-briefcase",     "Instructores con experiencia en la industria regiomontana"],
            ["bi-graph-up",      "Contenido práctico aplicable desde el primer día"],
            ["bi-mortarboard",   "Valor curricular en licenciatura y posgrado"]
          ].each do |icon, texto| %>
            <div class="col-md-6 d-flex align-items-center gap-2">
              <i class="bi <%= icon %>" style="color:var(--gold);font-size:18px;flex-shrink:0;"></i>
              <span class="text-white-50 small"><%= texto %></span>
            </div>
          <% end %>
        </div>
      </div>

    </div>

    <%# Columna derecha — Sidebar %>
    <div class="col-lg-4">
      <div class="sticky-top" style="top:85px; z-index:1;">
        <div class="border rounded-4 overflow-hidden shadow-sm">

          <%# Precio %>
          <div class="p-4 text-center" style="background:var(--navy);">
            <div class="text-white-50 small mb-1 text-uppercase" 
                 style="letter-spacing:0.08em;">Inversión</div>
            <div class="text-white fw-black" style="font-size:42px;line-height:1;">
              $<%= number_with_delimiter(@certification.price.to_i) %>
              <span class="text-white-50" style="font-size:16px;">MXN</span>
            </div>
          </div>

          <%# Detalles %>
          <div class="p-4 bg-white">
            <% [
              ["bi-calendar3",   "Inicio",     @certification.start_date&.strftime("%-d de %B, %Y")],
              ["bi-clock",       "Duración",   @certification.duration],
              ["bi-laptop",      "Modalidad",  @certification.modality],
              ["bi-people",      "Lugares",    "#{@certification.seats_available} disponibles"]
            ].each do |icon, label, value| %>
              <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                <i class="bi <%= icon %>" style="color:var(--gold);font-size:20px;width:24px;"></i>
                <div>
                  <div class="text-muted" style="font-size:11px;text-transform:uppercase;letter-spacing:0.05em;">
                    <%= label %>
                  </div>
                  <div class="fw-bold text-navy"><%= value %></div>
                </div>
              </div>
            <% end %>

            <button class="btn btn-gold w-100 py-3 fw-black mt-4 fs-5"
                    data-bs-toggle="modal" data-bs-target="#leadModal">
              Inscribirme ahora
            </button>

            <p class="text-center text-muted mt-2 mb-0" style="font-size:12px;">
              <i class="bi bi-shield-check me-1"></i>
              Tus datos están protegidos por FACPYA-UANL
            </p>
          </div>

        </div>

        <%# Contacto rápido %>
        <div class="mt-3 p-3 rounded-3 border text-center bg-light">
          <p class="small text-secondary mb-2">¿Tienes dudas? Contáctanos</p>
          <a href="mailto:certificaciones@facpya.uanl.mx" 
             class="small text-decoration-none fw-bold text-navy">
            <i class="bi bi-envelope me-1" style="color:var(--gold);"></i>
            certificaciones@facpya.uanl.mx
          </a>
        </div>

      </div>
    </div>

  </div>
</div>